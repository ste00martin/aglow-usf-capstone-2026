{
  "name": "expo-pytorch",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "setup": "npm install && npm run models:export",
    "setup:ios": "npm install && npm run models:export && npm run models:export:ios",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
